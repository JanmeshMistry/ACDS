# ============================================================
# ACDS - Environment Variables Example
# Copy this file to .env and fill in your real values
# ============================================================

# ── Threat Intelligence API Keys ────────────────────────
# Get free VirusTotal key: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=YOUR_VIRUSTOTAL_API_KEY_HERE

# Get free OTX key: https://otx.alienvault.com/
OTX_API_KEY=YOUR_ALIENVAULT_OTX_API_KEY_HERE

# ── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=acds_db

# ── Honeypot Ports ────────────────────────────────────────
WEB_HONEYPOT_HOST=0.0.0.0
WEB_HONEYPOT_PORT=5000
SSH_HONEYPOT_HOST=0.0.0.0
SSH_HONEYPOT_PORT=2222

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_PORT=8000
DJANGO_SECRET_KEY=change-this-to-a-long-random-string-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*

# ── Decision Engine Thresholds ───────────────────────────
BLOCK_REPUTATION_THRESHOLD=50
BLOCK_ATTEMPT_THRESHOLD=5
BRUTE_FORCE_WINDOW_SECONDS=60
RISK_SCORE_BLOCK_THRESHOLD=70
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_SEC=60

# ── Email Alerts ─────────────────────────────────────────
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM=acds@yourdomain.com
ALERT_EMAIL_TO=admin@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# ── GeoIP ─────────────────────────────────────────────────
# Download free GeoLite2-City.mmdb from: https://www.maxmind.com/
GEOIP_DB_PATH=data/GeoLite2-City.mmdb

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/acds.log
LOG_TO_FILE=true
